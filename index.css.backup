/* stylelint-disable */
@tailwind base;
@tailwind components;
@tailwind utilities;

/* Premium SaaS Design System - Student Survival Kit */

@layer base {
  :root {
    --radius: 0.75rem;
    
    /* Base colors - Light mode (Premium) */
    --background: 220 25% 97%;
    --foreground: 222 47% 11%;
    --card: 0 0% 100%;
    --card-foreground: 222 47% 11%;
    --popover: 0 0% 100%;
    --popover-foreground: 222 47% 11%;
    
    /* Primary - Deep Blue (Intelligence, Focus) */
    --primary: 221 83% 53%;
    --primary-foreground: 0 0% 100%;
    --primary-glow: 221 83% 53%;
    
    /* Secondary - Emerald Green (Growth, Success) */
    --secondary: 158 64% 52%;
    --secondary-foreground: 0 0% 100%;
    
    /* Muted - Subtle backgrounds */
    --muted: 220 14% 96%;
    --muted-foreground: 220 9% 46%;
    
    /* Accent - Purple (Creativity, Wisdom) */
    --accent: 262 83% 92%;
    --accent-foreground: 262 83% 48%;
    
    /* Semantic colors */
    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 100%;
    --success: 142 71% 45%;
    --warning: 38 92% 50%;
    --info: 199 89% 48%;
    
    /* Borders and inputs */
    --border: 220 13% 91%;
    --input: 220 13% 91%;
    --ring: 221 83% 53%;
    
    /* Glassmorphism */
    --glass-bg: 0 0% 100%;
    --glass-border: 220 13% 91%;
    --glass-shadow: 220 13% 15%;
    
    /* Education specific */
    --education-blue: 217 91% 60%;
    --education-green: 142 71% 45%;
    
    /* Charts - Educational palette */
    --chart-1: 221 83% 53%;
    --chart-2: 158 64% 52%;
    --chart-3: 262 83% 58%;
    --chart-4: 38 92% 50%;
    --chart-5: 199 89% 48%;
  }

  .dark {
    /* Base colors - Dark mode (Premium) */
    --background: 222 47% 11%;
    --foreground: 220 20% 98%;
    --card: 222 47% 15%;
    --card-foreground: 220 20% 98%;
    --popover: 222 47% 15%;
    --popover-foreground: 220 20% 98%;
    
    /* Primary - Brighter in dark mode */
    --primary: 221 83% 58%;
    --primary-foreground: 0 0% 100%;
    --primary-glow: 221 83% 58%;
    
    /* Secondary */
    --secondary: 158 64% 48%;
    --secondary-foreground: 0 0% 100%;
    
    /* Muted */
    --muted: 222 47% 18%;
    --muted-foreground: 220 14% 71%;
    
    /* Accent */
    --accent: 262 83% 25%;
    --accent-foreground: 262 83% 88%;
    
    /* Semantic colors - adjusted for dark mode */
    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 100%;
    --success: 142 71% 45%;
    --warning: 38 92% 50%;
    --info: 199 89% 48%;
    
    /* Borders and inputs */
    --border: 222 47% 20%;
    --input: 222 47% 20%;
    --ring: 221 83% 58%;
    
    /* Glassmorphism - dark mode */
    --glass-bg: 222 47% 15%;
    --glass-border: 222 47% 25%;
    --glass-shadow: 0 0% 0%;
    
    /* Charts */
    --chart-1: 221 83% 58%;
    --chart-2: 158 64% 52%;
    --chart-3: 262 83% 68%;
    --chart-4: 38 92% 60%;
    --chart-5: 199 89% 58%;
  }

  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
    font-synthesis-weight: none;
    text-rendering: optimizeLegibility;
  }
}

/* Premium Utility Classes */
@layer utilities {
  /* Glassmorphism */
  .glass {
    background: hsla(var(--glass-bg) / 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid hsla(var(--glass-border) / 0.2);
    box-shadow: 0 8px 32px 0 hsla(var(--glass-shadow) / 0.1);
  }

  .glass-strong {
    background: hsla(var(--glass-bg) / 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid hsla(var(--glass-border) / 0.3);
    box-shadow: 0 8px 32px 0 hsla(var(--glass-shadow) / 0.15);
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Smooth animations */
  .animate-fade-in {
    animation: fadeIn 0.3s ease-in;
  }

  .animate-slide-up {
    animation: slideUp 0.4s ease-out;
  }

  .animate-scale-in {
    animation: scaleIn 0.3s ease-out;
  }

  /* Loading skeleton */
  .skeleton {
    @apply animate-pulse bg-muted rounded;
  }

  /* Hover lift effect */
  .hover-lift {
    @apply transition-all duration-300 ease-out;
  }

  .hover-lift:hover {
    @apply -translate-y-1 shadow-lg;
  }

  /* Focus ring */
  .focus-ring {
    @apply focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-background;
  }

  /* Smooth scroll */
  .smooth-scroll {
    scroll-behavior: smooth;
  }
}

/* Animations */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Typography improvements */
@layer base {
  h1, h2, h3, h4, h5, h6 {
    @apply font-semibold tracking-tight;
  }

  h1 {
    @apply text-4xl lg:text-5xl;
  }

  h2 {
    @apply text-3xl lg:text-4xl;
  }

  h3 {
    @apply text-2xl lg:text-3xl;
  }

  h4 {
    @apply text-xl lg:text-2xl;
  }

  p {
    @apply leading-7;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    @apply bg-muted;
  }

  ::-webkit-scrollbar-thumb {
    @apply bg-muted-foreground/30 rounded-full;
  }

  ::-webkit-scrollbar-thumb:hover {
    @apply bg-muted-foreground/50;
  }
}

/* Component-specific styles */
@layer components {
  /* Premium card */
  .premium-card {
    @apply bg-card border border-border rounded-xl shadow-sm hover-lift;
  }

  /* Premium button */
  .premium-button {
    @apply inline-flex items-center justify-center rounded-lg text-sm font-medium transition-all duration-200;
    @apply focus-ring disabled:opacity-50 disabled:pointer-events-none;
  }

  /* Empty state */
  .empty-state {
    @apply flex flex-col items-center justify-center p-8 text-center;
  }

  /* Error state */
  .error-state {
    @apply flex flex-col items-center justify-center p-6 text-center bg-destructive/10 border border-destructive/20 rounded-lg;
  }

  /* Loading state */
  .loading-state {
    @apply flex items-center justify-center p-8;
  }
}

/* Smooth transitions for theme switching */
* {
  transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
}
    --sidebar-primary: 221 83% 53%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 222 47% 18%;
    --sidebar-accent-foreground: 210 40% 98%;
    --sidebar-border: 217 32% 17%;
    --sidebar-ring: 221 83% 53%;
    
    /* Gradients */
    --gradient-primary: linear-gradient(135deg, hsl(221 83% 53%) 0%, hsl(262 83% 58%) 100%);
    --gradient-card: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
    --gradient-background: linear-gradient(180deg, hsl(220 20% 98%) 0%, hsl(220 14% 96%) 100%);
    
    /* Shadows */
    --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06);
    --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .dark {
    /* Base colors - Dark mode */
    --background: 222 47% 11%;
    --foreground: 210 40% 98%;
    --card: 222 47% 14%;
    --card-foreground: 210 40% 98%;
    --popover: 222 47% 14%;
    --popover-foreground: 210 40% 98%;
    
    /* Primary - Brighter blue for dark mode */
    --primary: 217 91% 60%;
    --primary-foreground: 222 47% 11%;
    
    /* Secondary - Brighter green for dark mode */
    --secondary: 158 64% 52%;
    --secondary-foreground: 222 47% 11%;
    
    /* Muted */
    --muted: 217 32% 17%;
    --muted-foreground: 215 20% 65%;
    
    /* Accent - Darker purple for dark mode */
    --accent: 262 83% 18%;
    --accent-foreground: 262 83% 88%;
    
    /* Semantic colors */
    --destructive: 0 63% 31%;
    --destructive-foreground: 210 40% 98%;
    --success: 142 71% 45%;
    --warning: 38 92% 50%;
    --info: 199 89% 48%;
    
    /* Borders and inputs */
    --border: 217 32% 17%;
    --input: 217 32% 17%;
    --ring: 217 91% 60%;
    
    /* Education specific */
    --education-blue: 217 91% 60%;
    --education-green: 142 71% 45%;
    
    /* Charts - Adjusted for dark mode */
    --chart-1: 217 91% 60%;
    --chart-2: 158 64% 52%;
    --chart-3: 262 83% 68%;
    --chart-4: 38 92% 50%;
    --chart-5: 199 89% 48%;
    
    /* Sidebar */
    --sidebar-background: 222 47% 8%;
    --sidebar-foreground: 210 40% 98%;
    --sidebar-primary: 217 91% 60%;
    --sidebar-primary-foreground: 222 47% 11%;
    --sidebar-accent: 222 47% 15%;
    --sidebar-accent-foreground: 210 40% 98%;
    --sidebar-border: 217 32% 17%;
    --sidebar-ring: 217 91% 60%;
    
    /* Gradients */
    --gradient-primary: linear-gradient(135deg, hsl(217 91% 60%) 0%, hsl(262 83% 68%) 100%);
    --gradient-card: linear-gradient(135deg, rgba(34, 40, 49, 0.9) 0%, rgba(34, 40, 49, 0.7) 100%);
    --gradient-background: linear-gradient(180deg, hsl(222 47% 11%) 0%, hsl(222 47% 8%) 100%);
    
    /* Shadows */
    --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.3), 0 1px 2px rgba(0, 0, 0, 0.4);
    --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.5), 0 2px 6px rgba(0, 0, 0, 0.6);
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
  }
  
  h1, h2, h3, h4, h5, h6 {
    @apply font-semibold tracking-tight;
  }
}

@layer utilities {
  .gradient-text {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  
  .dark .glass-card {
    background: rgba(34, 40, 49, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
}
